rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Videos: public read, create allowed, update allowed (likes use increment transform)
    match /videos/{videoId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;  // Likes use field transforms (increment) which bypass resource checks
      allow delete: if request.auth != null;
    }

    // Likes sub-collection: public read, create once per fingerprint, no delete
    match /videos/{videoId}/likes/{fingerprint} {
      allow read: if true;
      allow create: if !exists(/databases/$(database)/documents/videos/$(videoId)/likes/$(fingerprint));
      allow delete: if false;
      allow update: if false;
    }

    // Channels: public read, create allowed (managed by API)
    match /channels/{channelId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // Trends: public read, admin only write
    match /trends/{trendId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Archives: public read, admin only write
    match /archives/{archiveId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Users: public read, create via API, update/delete blocked
    match /users/{userId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // Follows: public read, create/delete via API
    match /follows/{followId} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;
      allow update: if false;
    }
  }
}
