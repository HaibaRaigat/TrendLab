rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Videos: public read, no direct write (API only)
    match /videos/{videoId} {
      allow read: if true;
      allow create: if true; // Controlled by upload flow
      allow update: if request.resource.data.keys().hasOnly(['likes', 'archived', 'archiveId'])
                    || request.auth != null;
      allow delete: if request.auth != null;
    }

    // Likes sub-collection: one like per account (userId = document ID)
    match /videos/{videoId}/likes/{userId} {
      allow read: if true;
      allow create: if !exists(/databases/$(database)/documents/videos/$(videoId)/likes/$(userId));
      allow delete: if false;
      allow update: if false;
    }

    // Channels: public read, create allowed (managed by API)
    match /channels/{channelId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // Trends: public read, admin only write
    match /trends/{trendId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Archives: public read, admin only write
    match /archives/{archiveId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Users: public read, create via API (no auth required), update/delete blocked
    match /users/{userId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // Follows: public read, create/delete via API (no auth on client SDK)
    match /follows/{followId} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;
      allow update: if false;
    }
  }
}
